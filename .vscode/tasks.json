{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Validate official data",
      "type": "shell",
      "command": "Set-ExecutionPolicy -Scope Process Bypass; .\\run_analysis.ps1 -Stage validate",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-Command"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Run complete analysis",
      "type": "shell",
      "command": "Set-ExecutionPolicy -Scope Process Bypass; .\\run_analysis.ps1 -Stage all",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-Command"]
        }
      },
      "problemMatcher": []
    }
  ]
}
